# ── Required — must be set on Railway before first deploy ────────────────────

# PostgreSQL connection string (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# HMAC secret for signing admin tokens — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_SECRET=change_me_random_hex_64_chars

# Fernet key for encrypting Salla tokens + AI API keys at rest — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: losing this key makes all stored secrets unrecoverable
ENCRYPTION_KEY=change_me_fernet_key

# Your public backend URL (used to build Salla webhook + WhatsApp webhook URLs)
BASE_URL=https://your-backend.railway.app

# Comma-separated list of allowed frontend origins for CORS
ALLOWED_ORIGINS=https://your-store.salla.sa,https://your-backend.railway.app

# ── Salla App credentials (from Salla Partner Portal) ────────────────────────
SALLA_CLIENT_ID=your_salla_client_id
SALLA_CLIENT_SECRET=your_salla_client_secret
SALLA_WEBHOOK_SECRET=your_webhook_secret

# Filled automatically after OAuth — do not set manually unless needed
SALLA_ACCESS_TOKEN=
SALLA_REFRESH_TOKEN=

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────────
# Any string you choose — must match what you enter in Meta webhook settings
WHATSAPP_VERIFY_TOKEN=sallabot-wa

# ── AI Providers — set at least one, or configure per-store from admin panel ──
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
GROQ_API_KEY=gsk_xxxxxxxxxxxxx
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxx

# ── Optional tuning ───────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=20
UPLOAD_DIR=uploads

# Rotate encryption key (comma-separated old keys, decrypt-only):
# ENCRYPTION_KEYS_OLD=old_fernet_key_1,old_fernet_key_2

# Worker roles for multi-instance Railway deploys:
# WORKER_ROLE=web          # default
# ENABLE_DRAINERS=true
# ENABLE_PERIODIC=true
